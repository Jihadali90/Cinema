@model MoviesVM;

<div class="content">

    <div class="card mb-3">
        <div class="card-body">
            <div class="row flex-between-center">
                <div class="col-sm-auto mb-2 mb-sm-0">
                    <h6 class="mb-0">Showing 1-24 of 205 Products</h6>
                </div>
                <form method="get" class="d-flex align-items-center gap-2 mb-1">

                    <div class="col-sm-4 mb-1 p-2">
                        <!-- Input -->
                        <input type="text" name="name"
                               class="form-control"
                               placeholder="Search..."
                               value="" />
                    </div>
                </form>
                <div class="col-sm-auto">
                    <div class="row gx-2 align-items-center">
                        <div class="col-auto">
                            <form class="row gx-2">
                                <div class="col-auto"><small>Cinemas</small></div>
                                <div class="col-auto">
                                    <select class="form-select form-select-sm" aria-label="Bulk actions">
                                        <option selected="">Best Match</option>
                                        <option value="new">Newest</option>
                                        <option value="price">Price</option>
                                    </select>
                                </div>
                            </form>
                        </div>

                    </div>
                </div>
                <div class="col-sm-auto">
                    <div class="row gx-2 align-items-center">
                        <div class="col-auto">
                            <form class="row gx-2">
                                <div class="col-auto"><small>Categories </small></div>
                                <div class="col-auto">
                                    <select class="form-select form-select-sm" aria-label="Bulk actions">
                                        <option selected="">Best Match</option>
                                        <option value="new">Newest</option>
                                        <option value="price">Price</option>
                                    </select>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="card-body p-0 overflow-hidden">
            <div class="row g-0">
                @foreach (var item in Model.Movies)
                {
                    <div class="col-12 p-x1">
                        <div class="row">
                            <div class="col-sm-5 col-md-4">
                                <div class="position-relative h-sm-100">
                                    <a class="d-block h-100" href="../../../app/e-commerce/product/product-details.html"><img class="img-fluid object-fit-cover w-sm-100 h-sm-100 rounded-1 absolute-sm-centered" src="@item.Main_Img" alt="" /></a>
                                    <div class="badge rounded-pill bg-success position-absolute top-0 end-0 me-2 mt-2 fs-11 z-2">New</div>
                                </div>
                            </div>
                            <div class="col-sm-7 col-md-8">
                                <div class="row">
                                    <div class="col-lg-8">
                                        <h5 class="mt-3 mt-sm-0"><a class="text-1100 fs-9 fs-lg-8" href="../../../app/e-commerce/product/product-details.html">@item.Name </a></h5>
                                        <p class="fs-10 mb-2 mb-md-3"><a class="text-500" href="#!">@item.Category?.Name</a></p>
                                        <p class="fs-10 mb-2 mb-md-3"><a class="text-500" href="#!">@item.Cinema?.Name</a></p>
                                        <ul class="list-unstyled d-none d-lg-block">
                                            <li><p class="mt-3"> @item.Description</p></li>

                                        </ul>
                                    </div>
                                    <div class="col-lg-4 d-flex justify-content-between flex-column">
                                        <div>
                                            <span class="mb-0 text-primary">
                                                @((item.Price - (item.Price * (item.Discount ?? 0) / 100m)).ToString("C"))
                                            </span>
                                            <h5 class="fs-10 text-500 mb-0 mt-1">
                                                Discount:  <span class="ms-1">@item.Discount</span>
                                            </h5>

                                            <div class="d-none d-lg-block">

                                                <p class="fs-10 mb-1">
                                                    Status: <strong class="text-success">@item.Status</strong>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="mt-2"><a class="btn btn-sm btn-outline-secondary border-300 d-lg-block me-2 me-lg-0" href="#!"><span class="far fa-heart"></span><span class="ms-2 d-none d-md-inline-block">Favourite</span></a><a class="btn btn-sm btn-primary d-lg-block mt-lg-2" href="#!"><span class="fas fa-cart-plus"> </span><span class="ms-2 d-none d-md-inline-block">Add to Cart</span></a></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="pagination-container" style="text-align:center; margin-top:2px; margin-bottom:5px;">
            @if (Model.CurrentPage > 1)
            {
                <a href="?page=@(Model.CurrentPage - 1)"
                   style="margin:1px; padding:2px 6px; border:1px solid #ccc; border-radius:5px; text-decoration:none; font-size:0.8rem; color:#333; background:#f7f7f7;">
                    &laquo; Prev
                </a>
            }

            <!-- أرقام الصفحات -->
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                if (i == Model.CurrentPage)
                {
                    <span style="margin:1px; padding:2px 6px; border-radius:5px; background-color:#333; color:white; font-size:0.8rem;">
                        @i
                    </span>
                }
                else
                {
                    <a href="?page=@i"
                       style="margin:1px; padding:2px 6px; border:1px solid #ccc; border-radius:5px; text-decoration:none; font-size:0.8rem; color:#333; background:#f7f7f7;">
                        @i
                    </a>
                }
            }

            <!-- زرار Next -->
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a href="?page=@(Model.CurrentPage + 1)"
                   style="margin:1px; padding:2px 6px; border:1px solid #ccc; border-radius:5px; text-decoration:none; font-size:0.8rem; color:#333; background:#f7f7f7;">
                    Next &raquo;
                </a>
            }
        </div>

    </div>

    <!-- ===============================================-->
    <!--    End of Main Content-->
    <!-- ===============================================-->
    <script id="k3s9df">
        function confirmDelete(id) {
            Swal.fire({
                title: "Are you sure?",
                text: "You won't be able to revert this!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "Yes, delete it!"
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/Admin/Category/Delete/' + id;
                }
            });
        }
    </script>
